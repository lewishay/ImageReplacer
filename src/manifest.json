{
  "manifest_version": 3,
  "name": "ImageReplacer",
  "version": "1.0",
  "description": "A Firefox extension that allows you to replace images across the web",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage"
  ],
  "host_permissions": [ "<all_urls>" ],
  "background": {
    "scripts": [ "background.js" ],
    "type": "module"
  },
  "action": {
    "default_title": "ImageReplacer",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": [ "content.js" ],
      "css": [ "replacer.css" ],
      "run_at": "document_start"
    }
  ]
}