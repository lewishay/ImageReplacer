{
  "manifest_version": 3,
  "name": "ImageReplacer",
  "version": "1.0.2",
  "description": "A Firefox extension that allows you to replace images across the web",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "storage"
  ],
  "host_permissions": [ "<all_urls>" ],
  "background": {
    "scripts": [ "background.js" ],
    "type": "module"
  },
  "action": {
    "default_title": "ImageReplacer",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": [ "content.js" ],
      "css": [ "replacer.css" ],
      "run_at": "document_start"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "image-replacer@extension",
      "data_collection_permissions": {
        "required": [ "none" ]
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}