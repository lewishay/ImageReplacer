  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/lewishay/ImageReplacer/issues"
  },
  "homepage": "https://github.com/lewishay/ImageReplacer#readme",
  "devDependencies": {
    "@types/firefox-webext-browser": "^143.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
