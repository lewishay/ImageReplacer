{
  "name": "image-replacer",
  "version": "1.0.0",
  "description": "A Firefox extension that allows you to replace images across the web",
  "main": "index.js",
  "scripts": {
    "build": "node build.js",
    "copy": "del /Q dist\\*.html dist\\*.css && xcopy src\\*.html dist /Y /I && xcopy src\\*.css dist /Y /I"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lewishay/ImageReplacer.git"
  },
  "keywords": [],
